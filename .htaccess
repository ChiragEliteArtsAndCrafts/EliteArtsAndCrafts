# ============================================================
# Elite Arts & Crafts — .htaccess
# Performance, security, and SEO redirects for legacy URLs.
# Apache 2.4+ with mod_rewrite, mod_deflate, mod_expires, mod_headers.
# ============================================================

# ---------- Force HTTPS ----------
<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # ---------- Canonical host: non-www ----------
  RewriteCond %{HTTP_HOST} ^www\.eliteartsandcrafts\.com$ [NC]
  RewriteRule ^(.*)$ https://eliteartsandcrafts.com/$1 [L,R=301]

  # ---------- Legacy URL redirects (preserve old SEO) ----------
  # Old category pages → archive section on the new single-page design
  RewriteRule ^category/?[0-9]*/?$           /#products       [R=301,L,NE]
  RewriteRule ^category/.*$                   /#products       [R=301,L,NE]

  # Old product / catalog pages
  RewriteRule ^product/?.*$                   /#products       [R=301,L,NE]
  RewriteRule ^products/?.*$                  /#products       [R=301,L,NE]
  RewriteRule ^catalog/?.*$                   /#products       [R=301,L,NE]
  RewriteRule ^catalogue/?.*$                 /#products       [R=301,L,NE]

  # Old static pages → equivalent anchors on the new home
  RewriteRule ^about/?.*$                     /#about          [R=301,L,NE]
  RewriteRule ^aboutus/?.*$                   /#about          [R=301,L,NE]
  RewriteRule ^about-us/?.*$                  /#about          [R=301,L,NE]
  RewriteRule ^contact/?.*$                   /#contact        [R=301,L,NE]
  RewriteRule ^contactus/?.*$                 /#contact        [R=301,L,NE]
  RewriteRule ^contact-us/?.*$                /#contact        [R=301,L,NE]
  RewriteRule ^enquiry/?.*$                   /#contact        [R=301,L,NE]
  RewriteRule ^enquire/?.*$                   /#contact        [R=301,L,NE]
  RewriteRule ^home/?.*$                      /                [R=301,L,NE]
  RewriteRule ^index\.php$                    /                [R=301,L,NE]

  # Old index endings
  RewriteRule ^(.+)/index\.html?$             /$1/             [R=301,L,NE]
</IfModule>

# ---------- Compression ----------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript application/xml
  AddOutputFilterByType DEFLATE application/json application/ld+json application/rss+xml
  AddOutputFilterByType DEFLATE application/xml+rss application/xhtml+xml
  AddOutputFilterByType DEFLATE image/svg+xml image/x-icon
  AddOutputFilterByType DEFLATE font/ttf font/otf font/woff font/woff2 application/font-woff application/font-woff2
</IfModule>

# ---------- Brotli (if available) ----------
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType BROTLI_COMPRESS application/javascript application/json application/ld+json
  AddOutputFilterByType BROTLI_COMPRESS image/svg+xml
</IfModule>

# ---------- Long-lived cache for static assets ----------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                              "access plus 1 month"

  ExpiresByType text/html                     "access plus 1 hour"
  ExpiresByType text/css                      "access plus 1 month"
  ExpiresByType text/javascript               "access plus 1 month"
  ExpiresByType application/javascript        "access plus 1 month"
  ExpiresByType application/x-javascript      "access plus 1 month"

  ExpiresByType image/jpeg                    "access plus 1 year"
  ExpiresByType image/png                     "access plus 1 year"
  ExpiresByType image/gif                     "access plus 1 year"
  ExpiresByType image/webp                    "access plus 1 year"
  ExpiresByType image/svg+xml                 "access plus 1 year"
  ExpiresByType image/x-icon                  "access plus 1 year"

  ExpiresByType font/ttf                      "access plus 1 year"
  ExpiresByType font/otf                      "access plus 1 year"
  ExpiresByType font/woff                     "access plus 1 year"
  ExpiresByType font/woff2                    "access plus 1 year"

  ExpiresByType application/pdf               "access plus 1 month"
  ExpiresByType application/xml               "access plus 1 hour"
  ExpiresByType text/xml                      "access plus 1 hour"
</IfModule>

<IfModule mod_headers.c>
  # Cache-Control fallback
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico|woff|woff2|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>

  # ---------- Security headers ----------
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always unset X-Powered-By
  Header unset Server
</IfModule>

# ---------- Default document ----------
DirectoryIndex index.html

# ---------- Custom 404 (falls back to home if not present) ----------
ErrorDocument 404 /

# ---------- Disable directory listing ----------
Options -Indexes

# ---------- Block access to source/dev files ----------
<FilesMatch "\.(docx|psd|sketch|fig|env|log|bak|swp|orig|map)$">
  Require all denied
</FilesMatch>

<Files ".htaccess">
  Require all denied
</Files>

<Files ".git">
  Require all denied
</Files>
